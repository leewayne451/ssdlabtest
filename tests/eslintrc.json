{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:security/recommended"
  ],
  "plugins": ["security"],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "script"
  },
  "ignorePatterns": [
    "node_modules/",
    "public/",
    "gitea/",
    "*.txt"
  ],
  "rules": {
    "no-unused-vars": "warn"
  }
}
